# ============================================
# AI Assistant 环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================

# --- 加密密钥 ---
# 生产环境必须修改！用于 API Key 加密存储
ENCRYPTION_KEY=change-this-to-a-random-string-in-production

# --- LLM API Keys ---
# 智谱 AI
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI / 兼容接口
# OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- 日志级别 ---
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=info

# --- 前端环境变量 ---
# 生产环境留空（通过 Nginx 代理）
# 开发环境可设为 http://localhost:8000/api
NEXT_PUBLIC_BACKEND_URL=
