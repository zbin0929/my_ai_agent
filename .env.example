# ============================================
# AI Assistant 环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================

# --- 加密密钥 ---
# 生产环境必须修改！用于 API Key 加密存储
ENCRYPTION_KEY=change-this-to-a-random-string-in-production

# --- LLM API Keys ---
# 智谱 AI
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI / 兼容接口
# OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 阿里云百炼（通义千问）
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Moonshot AI（Kimi）
# MOONSHOT_API_KEY=your_moonshot_api_key_here

# --- 联网搜索 API Key ---
# ZHIPU_SEARCH_API_KEY=your_zhipu_search_api_key_here

# --- 安全配置 ---
# 管理接口认证令牌（生产环境必须设置！）
# ADMIN_TOKEN=your_random_admin_token_here

# --- CORS 跨域配置 ---
# 允许访问的前端域名（逗号分隔），默认 http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS=https://your-production-domain.com

# --- 日志级别 ---
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=info

# --- 前端环境变量 ---
# 生产环境留空（通过 Nginx 代理）
# 开发环境可设为 http://localhost:8000/api
NEXT_PUBLIC_BACKEND_URL=
